#!/usr/bin/env python3
import os
import sys
import argparse
import yaml
import jsonschema
import json
import shutil
from jinja2 import Environment, FileSystemLoader

STEGOS_ROOT = os.environ.get("STEGOS_ROOT", "/stegos")

def get_group_dir(folder_type, group_name):
    return os.path.join(STEGOS_ROOT, folder_type, group_name)

def check_group_exists(group_name):
    cont_dir = get_group_dir("containers", group_name)
    conf_dir = get_group_dir("conf", group_name)
    if not os.path.isdir(cont_dir) and not os.path.isdir(conf_dir):
        print(f"Warning: Stegmap target group '{group_name}' not fully present at {STEGOS_ROOT}. Ensure drive is mounted.", file=sys.stderr)

def find_package(group_name, pkg_name, target_repo=None):
    repos_dir = get_group_dir("repos", group_name)
    if not os.path.isdir(repos_dir):
        print(f"Error: Repos directory {repos_dir} does not exist.")
        sys.exit(1)
        
    found_paths = []
    for root, dirs, files in os.walk(repos_dir):
        if "manifest.yml" in files:
            if os.path.basename(root) == pkg_name:
                found_paths.append(root)
                
    if not found_paths:
        print(f"Error: Package '{pkg_name}' not found in any repo under {repos_dir}")
        sys.exit(1)
        
    if target_repo:
        filtered = [p for p in found_paths if f"/{target_repo}/" in p or p.endswith(f"/{target_repo}")]
        if not filtered:
            print(f"Error: Package '{pkg_name}' not found in repo '{target_repo}'")
            sys.exit(1)
        found_paths = filtered
            
    if len(found_paths) > 1:
        print(f"Error: Multiple packages named '{pkg_name}' found. Please disambiguate using --repo.")
        for p in found_paths:
            print(f"  - {p}")
        sys.exit(1)
        
    return found_paths[0]

def resolve_config(schema, pkg_conf, global_conf, cli_conf, reconfigure):
    final_conf = {}
    properties = schema.get("properties", {})
    required = schema.get("required", [])
    
    needs_prompt = False
    for key, prop in properties.items():
        has_val = False
        if key in cli_conf:
            has_val = True
        elif not reconfigure:
            if key in pkg_conf or key in global_conf:
                has_val = True
        if not has_val:
            needs_prompt = True

    if needs_prompt:
        print("\n--- Configuration Required ---")
        
    for key, prop in properties.items():
        if key in cli_conf:
            final_conf[key] = cli_conf[key]
            continue
        elif not reconfigure:
            if key in pkg_conf:
                final_conf[key] = pkg_conf[key]
                continue
            elif key in global_conf:
                final_conf[key] = global_conf[key]
                continue
                
        desc = prop.get("description", "")
        
        # Determine default for prompt
        default = ""
        if key in pkg_conf:
            default = pkg_conf[key]
        elif key in global_conf:
            default = global_conf[key]
        elif "default" in prop:
            default = prop["default"]
            
        is_req = key in required
        
        prompt_text = f"{key}"
        if desc: prompt_text += f" ({desc})"
        if default != "": prompt_text += f" [default: {default}]"
        prompt_text += ": "

        while True:
            user_input = input(prompt_text)
            if not user_input and default != "":
                user_val = default
            elif not user_input and is_req:
                print("This field is required. Please provide a value.")
                continue
            elif not user_input and not is_req:
                user_val = None
                break
            else:
                user_val = user_input
            
            # Type casting based on schema
            val_type = prop.get("type", "string")
            if user_val is not None:
                try:
                    if val_type == "integer":
                        user_val = int(user_val)
                    elif val_type == "number":
                        user_val = float(user_val)
                    elif val_type == "boolean":
                        user_val = str(user_val).lower() in ("true", "1", "yes", "y")
                except ValueError:
                    print(f"Invalid type. Expected {val_type}.")
                    continue
                
            if user_val is not None:
                final_conf[key] = user_val
            break
            
    if needs_prompt:
        print("------------------------------\n")
        
    return final_conf

def process_skeleton(skeletons, pkg_dir, out_dir, env, final_conf, global_conf):
    for skel in skeletons:
        src = skel.get("src")
        dest = skel.get("dest", "./")
        
        if not src:
            continue
            
        src_path = os.path.join(pkg_dir, src)
        if not os.path.isdir(src_path):
            print(f"Warning: Skeleton source directory '{src}' not found.")
            continue
            
        dest_base = os.path.normpath(os.path.join(out_dir, dest))
        if not dest_base.startswith(out_dir):
            print(f"Warning: Skeleton dest '{dest}' tries to escape target directory. Skipping.")
            continue
            
        for root, dirs, files in os.walk(src_path):
            rel_dir = os.path.relpath(root, src_path)
            if rel_dir == ".":
                target_dir = dest_base
            else:
                target_dir = os.path.join(dest_base, rel_dir)
                
            os.makedirs(target_dir, exist_ok=True)
            
            for f in files:
                src_file = os.path.join(root, f)
                target_file = os.path.join(target_dir, f)
                    
                if os.path.exists(target_file):
                    print(f"Skeleton: Skipping existing file {target_file}")
                    continue
                    
                shutil.copy2(src_file, target_file)
                print(f"Skeleton: Copied static file {target_file}")

def main():
    parser = argparse.ArgumentParser(description="StegOS Package Manager")
    subparsers = parser.add_subparsers(dest="command", required=True)

    install_p = subparsers.add_parser("install", help="Install a package into a target group")
    install_p.add_argument("package_name", help="Name of the package to search for in the group's repos")
    install_p.add_argument("--group", required=True, help="Target Stegmap group name")
    install_p.add_argument("--repo", help="Disambiguate if multiple repos provide the same package")
    install_p.add_argument("--config", help="Path to a JSON file containing configuration values")
    install_p.add_argument("--reconfigure", action="store_true", help="Force prompts for already configured values")
    
    args = parser.parse_args()
    
    if args.command == "install":
        check_group_exists(args.group)
        
        pkg_dir = find_package(args.group, args.package_name, args.repo)
        manifest_path = os.path.join(pkg_dir, "manifest.yml")
        
        with open(manifest_path, "r") as f:
            manifest = yaml.safe_load(f)
            
        pkg_name = manifest.get("name")
        if not pkg_name:
            print("Error: manifest.yml is missing a 'name' field.")
            sys.exit(1)
            
        print(f"Installing package: {pkg_name} (v{manifest.get('version', 'unknown')}) from {pkg_dir}")
        
        conf_dir = get_group_dir("conf", args.group)
        os.makedirs(conf_dir, exist_ok=True)
        
        # Load Global Config
        global_conf_path = os.path.join(conf_dir, "global.json")
        global_conf = {}
        if os.path.isfile(global_conf_path):
            with open(global_conf_path, "r") as f:
                global_conf = json.load(f)
                
        # Load Package Config
        pkg_conf_path = os.path.join(conf_dir, f"{pkg_name}.json")
        pkg_conf = {}
        if os.path.isfile(pkg_conf_path):
            with open(pkg_conf_path, "r") as f:
                pkg_conf = json.load(f)
                
        # Load CLI Config
        cli_conf = {}
        if args.config:
            if not os.path.isfile(args.config):
                print(f"Error: Config file {args.config} not found.")
                sys.exit(1)
            with open(args.config, "r") as f:
                cli_conf = json.load(f)
                
        config_schema = manifest.get("config_schema", {})
        final_conf = {}
        
        if config_schema:
            final_conf = resolve_config(config_schema, pkg_conf, global_conf, cli_conf, args.reconfigure)
            try:
                jsonschema.validate(instance=final_conf, schema=config_schema)
            except jsonschema.exceptions.ValidationError as e:
                print(f"Configuration validation failed: {e.message}")
                sys.exit(1)
        
        # Save final unified config persistently
        with open(pkg_conf_path, "w") as f:
            json.dump(final_conf, f, indent=4)
        
        out_dir = os.path.join(get_group_dir("containers", args.group), pkg_name)
        os.makedirs(out_dir, exist_ok=True)
        
        env = Environment(loader=FileSystemLoader(pkg_dir))
        
        # Process deployers
        deployers = manifest.get("deployers", {})
        for dep_type, dep_config in deployers.items():
            if dep_type == "docker-compose":
                # 1. Process Skeleton data for this deployer
                skeletons = dep_config.get("skeleton", [])
                if skeletons:
                    process_skeleton(skeletons, pkg_dir, out_dir, env, final_conf, global_conf)
                
                # 2. Process templates
                for t in templates:
                    src = t.get("src")
                    dest = t.get("dest")
                    if src and dest:
                        template = env.get_template(src)
                        # Expose both config and global_config to Jinja
                        rendered = template.render(config=final_conf, global_config=global_conf)
                        
                        dest_path = os.path.normpath(os.path.join(out_dir, dest))
                        if not dest_path.startswith(out_dir):
                            print(f"Warning: template dest '{dest}' tries to escape target directory. Skipping.")
                            continue
                            
                        os.makedirs(os.path.dirname(dest_path), exist_ok=True)
                        with open(dest_path, "w") as f:
                            f.write(rendered)
                        print(f"Rendered: {dest_path}")
            else:
                print(f"Warning: Unknown deployer type '{dep_type}'")
                
        print(f"\nSuccessfully installed {pkg_name} to {out_dir}!")

if __name__ == "__main__":
    main()
