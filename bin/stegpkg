#!/usr/bin/env python3
import os
import sys
import argparse
import subprocess
import yaml
import jsonschema
import json
import shutil
from jinja2 import Environment, FileSystemLoader

STEGOS_ROOT = os.environ.get("STEGOS_ROOT", "/stegos")

class GroupManager:
    @staticmethod
    def resolve_group(group_prefix=None):
        containers_base = os.path.join(STEGOS_ROOT, "containers")
        if not os.path.isdir(containers_base):
            if group_prefix:
                return group_prefix
            else:
                print("Error: No groups exist and no group specified.")
                sys.exit(1)
        
        all_groups = os.listdir(containers_base)
        
        if group_prefix is None:
            if len(all_groups) == 1:
                return all_groups[0]
            elif len(all_groups) > 1:
                print(f"Error: Multiple groups exist. You must specify --group. Available: {all_groups}")
                sys.exit(1)
            else:
                print("Error: No groups exist and no group specified.")
                sys.exit(1)
        
        matches = []
        for d in all_groups:
            if d == group_prefix or d.startswith(f"{group_prefix}_"):
                matches.append(d)
                
        if len(matches) == 1:
            return matches[0]
        elif len(matches) > 1:
            print(f"Error: Multiple groups match '{group_prefix}': {matches}")
            sys.exit(1)
        
        # If 0 matches, assume the name literally (stegmap might create it later)
        return group_prefix

class CapabilityManager:
    def __init__(self, engine):
        self.engine = engine
        self.state = {}
        self.refresh()

    def refresh(self):
        self.state = {}
        if not os.path.isdir(self.engine.cont_dir):
            return
            
        import yaml
        for d in os.listdir(self.engine.cont_dir):
            state_file = os.path.join(self.engine.cont_dir, d, ".stegpkg-state.json")
            if os.path.isfile(state_file):
                try:
                    with open(state_file, "r") as f:
                        state = json.load(f)
                    pkg_name = state.get("package")
                    if pkg_name:
                        # We use find_package_dir without specifying repo, assuming unique names
                        pkg_dir = self.engine.find_package_dir(pkg_name)
                        manifest_path = os.path.join(pkg_dir, "manifest.yml")
                        if os.path.isfile(manifest_path):
                            with open(manifest_path, "r") as mf:
                                manifest = yaml.safe_load(mf)
                            provides = manifest.get("capabilities", {}).get("provides", [])
                            for cap in provides:
                                c_name = cap.get("name")
                                if c_name:
                                    if c_name not in self.state:
                                        self.state[c_name] = {}
                                    self.state[c_name][d] = {
                                        "injector": cap.get("injectors", {})
                                    }
                except Exception:
                    pass

    def register_provider(self, cap_name, instance_name, injector_rules):
        # Only registers in memory for the duration of this CLI run
        if cap_name not in self.state:
            self.state[cap_name] = {}
        self.state[cap_name][instance_name] = {
            "injector": injector_rules
        }

    def get_providers(self, cap_name):
        return self.state.get(cap_name, {})

class ConfigResolver:
    @staticmethod
    def resolve(schema, pkg_conf, global_conf, cli_conf, reconfigure, non_interactive):
        final_conf = {}
        properties = schema.get("properties", {})
        required = schema.get("required", [])
        
        needs_prompt = False
        for key, prop in properties.items():
            if key in cli_conf:
                continue
            if not reconfigure and key in pkg_conf:
                continue
            if "default" not in prop and key not in pkg_conf and key not in cli_conf:
                 needs_prompt = True

        if needs_prompt and non_interactive:
            print("Error: Missing required configuration values, and --non-interactive is set.")
            sys.exit(1)
            
        if needs_prompt:
            print("\n--- Configuration Required ---")
            
        for key, prop in properties.items():
            if key in cli_conf:
                final_conf[key] = cli_conf[key]
                continue
            elif not reconfigure and key in pkg_conf:
                final_conf[key] = pkg_conf[key]
                continue
                
            desc = prop.get("description", "")
            
            # Default determination (Strictly separate from global_conf)
            default = ""
            if key in pkg_conf:
                default = pkg_conf[key]
            elif "default" in prop:
                default = prop["default"]
                
            is_req = key in required
            
            if non_interactive:
                if default != "":
                    final_conf[key] = default
                    continue
                elif is_req:
                    print(f"Error: Missing required value for '{key}'")
                    sys.exit(1)
                else:
                    continue
            
            prompt_text = f"{key}"
            if desc: prompt_text += f" ({desc})"
            if default != "": prompt_text += f" [default: {default}]"
            prompt_text += ": "

            while True:
                user_input = input(prompt_text)
                if not user_input and default != "":
                    user_val = default
                elif not user_input and is_req:
                    print("This field is required.")
                    continue
                elif not user_input and not is_req:
                    user_val = None
                    break
                else:
                    user_val = user_input
                
                val_type = prop.get("type", "string")
                if user_val is not None:
                    try:
                        if val_type == "integer":
                            user_val = int(user_val)
                        elif val_type == "number":
                            user_val = float(user_val)
                        elif val_type == "boolean":
                            user_val = str(user_val).lower() in ("true", "1", "yes", "y")
                    except ValueError:
                        print(f"Invalid type. Expected {val_type}.")
                        continue
                    
                if user_val is not None:
                    final_conf[key] = user_val
                break
                
        if needs_prompt:
            print("------------------------------\n")
            
        return final_conf

class DeployerBase:
    def __init__(self, name, config, pkg_dir, out_dir, env, final_conf, global_conf, manifest, instance_name):
        self.name = name
        self.config = config
        self.pkg_dir = pkg_dir
        self.out_dir = out_dir
        self.env = env
        self.final_conf = final_conf
        self.global_conf = global_conf
        self.manifest = manifest
        self.instance_name = instance_name

    def deploy(self, cap_manager):
        raise NotImplementedError
        
    def _process_skeleton(self, skeletons):
        for skel in skeletons:
            src = skel.get("src")
            dest = skel.get("dest", "./")
            if not src:
                continue
            src_path = os.path.join(self.pkg_dir, src)
            if not os.path.isdir(src_path):
                print(f"Warning: Skeleton src '{src}' not found.")
                continue
            dest_base = os.path.normpath(os.path.join(self.out_dir, dest))
            if not dest_base.startswith(self.out_dir):
                continue
            for root, dirs, files in os.walk(src_path):
                rel_dir = os.path.relpath(root, src_path)
                target_dir = dest_base if rel_dir == "." else os.path.join(dest_base, rel_dir)
                os.makedirs(target_dir, exist_ok=True)
                for f in files:
                    src_file = os.path.join(root, f)
                    target_file = os.path.join(target_dir, f)
                    if os.path.exists(target_file):
                        continue
                    shutil.copy2(src_file, target_file)

class DockerComposeDeployer(DeployerBase):
    def deploy(self, cap_manager):
        skeletons = self.config.get("skeleton", [])
        if skeletons:
            self._process_skeleton(skeletons)
            
        # Compute exports
        exports_raw = self.manifest.get("capabilities", {}).get("exports", {})
        exports = {}
        for k, v in exports_raw.items():
            if isinstance(v, str):
                t = self.env.from_string(v)
                exports[k] = t.render(config=self.final_conf, global_config=self.global_conf)
            else:
                exports[k] = v
                
        # Compute injected_env from capabilities
        consumes = self.manifest.get("capabilities", {}).get("consumes", [])
        enabled_caps = self.final_conf.get("_enabled_capabilities", [])
        
        injected_env = {}
        for cap in consumes:
            if cap not in enabled_caps:
                continue
                
            selected_providers = enabled_caps[cap]
            if not isinstance(selected_providers, list):
                selected_providers = [selected_providers]
                
            all_providers = cap_manager.get_providers(cap)
            for prov_id in selected_providers:
                if prov_id in all_providers:
                    provider_info = all_providers[prov_id]
                    injectors = provider_info.get("injector", {}) # Note: changed from 'injectors' to 'injector' to match register_provider format
                    dc_injector = injectors.get("docker-compose", {})
                    env_rules = dc_injector.get("env", {})
                    for ek, ev in env_rules.items():
                        t = self.env.from_string(ev)
                        val = t.render(consumer={"config": self.final_conf, "exports": exports})
                        injected_env[ek] = val

        # Process Templates
        templates = self.config.get("templates", [{"src": "docker-compose.yml.j2", "dest": "docker-compose.yml"}])
        for t in templates:
            src = t.get("src")
            dest = t.get("dest")
            if src and dest:
                if not os.path.exists(os.path.join(self.pkg_dir, src)):
                    print(f"Warning: Template {src} not found in package.")
                    continue
                
                with open(os.path.join(self.pkg_dir, src), "r") as f:
                    template_content = f.read()
                    
                t = self.env.from_string(template_content)
                rendered = t.render(config=self.final_conf, global_config=self.global_conf, injected_env=injected_env)
                
                dest_path = os.path.join(self.out_dir, os.path.normpath(dest))
                if os.path.dirname(dest_path):
                    os.makedirs(os.path.dirname(dest_path), exist_ok=True)
                with open(dest_path, "w") as f:
                    f.write(rendered)
                    
        # Write state file for stegctl
        state = {
            "deployer": "docker-compose",
            "package": self.manifest.get("name"),
            "instance": self.instance_name
        }
        with open(os.path.join(self.out_dir, ".stegpkg-state.json"), "w") as f:
            json.dump(state, f)

class PackageEngine:
    def __init__(self, group_prefix):
        self.group_name = GroupManager.resolve_group(group_prefix)
        self.conf_dir = os.path.join(STEGOS_ROOT, "conf", self.group_name)
        self.cont_dir = os.path.join(STEGOS_ROOT, "containers", self.group_name)
        self.repo_dir = os.path.join(STEGOS_ROOT, "repos", self.group_name)
        
        os.makedirs(self.conf_dir, exist_ok=True)
        os.makedirs(self.cont_dir, exist_ok=True)
        
        self.cap_manager = CapabilityManager(self)
        
        # Load Global Config
        self.global_conf = {}
        gc_path = os.path.join(self.conf_dir, "global.json")
        if os.path.isfile(gc_path):
            with open(gc_path, "r") as f:
                self.global_conf = json.load(f)

    def find_package_dir(self, pkg_name, target_repo=None):
        if not os.path.isdir(self.repo_dir):
            print(f"Error: Repos directory {self.repo_dir} does not exist.")
            sys.exit(1)
            
        found = []
        for root, dirs, files in os.walk(self.repo_dir):
            if "manifest.yml" in files and os.path.basename(root) == pkg_name:
                found.append(root)
                
        if not found:
            print(f"Error: Package '{pkg_name}' not found.")
            sys.exit(1)
            
        if target_repo:
            filtered = [p for p in found if f"/{target_repo}/" in p or p.endswith(f"/{target_repo}")]
            if not filtered:
                print(f"Error: Package '{pkg_name}' not found in repo '{target_repo}'")
                sys.exit(1)
            found = filtered
                
        if len(found) > 1:
            print(f"Error: Multiple packages named '{pkg_name}' found. Use --repo.")
            sys.exit(1)
            
        return found[0]

    def process_package(self, pkg_dir, cli_conf=None, reconfigure=False, non_interactive=False, instance_id=None):
        if cli_conf is None:
            cli_conf = {}
            
        manifest_path = os.path.join(pkg_dir, "manifest.yml")
        with open(manifest_path, "r") as f:
            manifest = yaml.safe_load(f)
            
        pkg_name = manifest.get("name")
        is_singleton = manifest.get("singleton", False)
        
        existing_instances = []
        if os.path.isdir(self.cont_dir):
            for d in os.listdir(self.cont_dir):
                state_file = os.path.join(self.cont_dir, d, ".stegpkg-state.json")
                if os.path.isfile(state_file):
                    with open(state_file, "r") as f:
                        try:
                            state = json.load(f)
                            if state.get("package") == pkg_name:
                                existing_instances.append(d)
                        except:
                            pass
                            
        if instance_id:
            instance_name = instance_id
        else:
            if reconfigure:
                if len(existing_instances) == 1:
                    instance_name = existing_instances[0]
                elif len(existing_instances) > 1:
                    print(f"Error: Multiple instances of '{pkg_name}' exist. Please specify --id to reconfigure. Available: {existing_instances}")
                    sys.exit(1)
                else:
                    print(f"Error: Cannot reconfigure. No instances of '{pkg_name}' found.")
                    sys.exit(1)
            else:
                import uuid
                instance_name = f"{pkg_name}-{uuid.uuid4().hex[:8]}"
                
        if is_singleton and instance_name not in existing_instances and existing_instances:
            print(f"Error: '{pkg_name}' is a singleton package and is already installed. Use --reconfigure to modify it.")
            sys.exit(1)
                
        pkg_conf_path = os.path.join(self.conf_dir, f"{instance_name}.json")
        
        pkg_conf = {}
        if os.path.isfile(pkg_conf_path):
            with open(pkg_conf_path, "r") as f:
                pkg_conf = json.load(f)
                
        config_schema = manifest.get("config_schema", {})
        conditional_schemas = manifest.get("conditional_config_schema", {})
        
        enabled_caps_raw = pkg_conf.get("_enabled_capabilities", {})
        enabled_caps = {}
        if isinstance(enabled_caps_raw, list):
            for cap in enabled_caps_raw:
                provs = self.cap_manager.get_providers(cap)
                enabled_caps[cap] = list(provs.keys())
        else:
            enabled_caps = enabled_caps_raw
            
        consumes_raw = manifest.get("capabilities", {}).get("consumes", [])
        consumes = {}
        if isinstance(consumes_raw, list):
            for c in consumes_raw:
                consumes[c] = {}
        else:
            consumes = consumes_raw
        
        if consumes and not non_interactive:
            for cap_name, cap_rules in consumes.items():
                provs = self.cap_manager.get_providers(cap_name)
                if not provs:
                    continue
                    
                prov_list = list(provs.keys())
                print(f"\nIntegration available: '{cap_name}'")
                
                max_provs = cap_rules.get("max_providers")
                if max_provs:
                    print(f"(Note: This app allows a maximum of {max_provs} provider(s) for this integration)")
                    
                print("Available providers:")
                for idx, p_name in enumerate(prov_list):
                    print(f"  {idx+1}. {p_name}")
                
                default_sel = []
                if cap_name in enabled_caps:
                    for p in enabled_caps[cap_name]:
                        if p in prov_list:
                            default_sel.append(str(prov_list.index(p) + 1))
                if not default_sel and not pkg_conf:
                    if max_provs and max_provs < len(prov_list):
                        default_sel = [] # Don't select anything if limit is strictly smaller to avoid guessing
                    else:
                        default_sel = ["1"]
                
                default_str = ",".join(default_sel)
                
                if reconfigure or not pkg_conf:
                    while True:
                        ans = input(f"Select providers to enable (comma separated list of numbers, or empty to skip) [default: {default_str}]: ").strip()
                        if not ans and default_str:
                            ans = default_str
                        
                        selected = []
                        if ans:
                            for part in ans.split(","):
                                part = part.strip()
                                if part.isdigit():
                                    idx = int(part) - 1
                                    if 0 <= idx < len(prov_list):
                                        selected.append(prov_list[idx])
                                        
                        if max_provs and len(selected) > max_provs:
                            print(f"Error: You can only select up to {max_provs} provider(s). Please try again.")
                            continue
                                        
                        if selected:
                            enabled_caps[cap_name] = selected
                        elif cap_name in enabled_caps:
                            del enabled_caps[cap_name]
                        
                        break
        
        for cap_name, cond_schema in conditional_schemas.items():
            if cap_name in enabled_caps and enabled_caps[cap_name] and self.cap_manager.get_providers(cap_name):
                if "properties" in cond_schema:
                    config_schema.setdefault("properties", {}).update(cond_schema["properties"])
                if "required" in cond_schema:
                    config_schema.setdefault("required", []).extend(cond_schema["required"])
                    
        final_conf = {}
        
        if config_schema:
            final_conf = ConfigResolver.resolve(config_schema, pkg_conf, self.global_conf, cli_conf, reconfigure, non_interactive)
            try:
                jsonschema.validate(instance=final_conf, schema=config_schema)
            except jsonschema.exceptions.ValidationError as e:
                print(f"Validation failed: {e.message}")
                sys.exit(1)
                
        final_conf["_enabled_capabilities"] = enabled_caps
                
        # Save package config
        with open(pkg_conf_path, "w") as f:
            json.dump(final_conf, f, indent=4)
            
        out_dir = os.path.join(self.cont_dir, instance_name)
        os.makedirs(out_dir, exist_ok=True)
        
        env = Environment(loader=FileSystemLoader(pkg_dir))
        
        deployers = manifest.get("deployers", {})
        for dep_type, dep_config in deployers.items():
            if dep_type == "docker-compose":
                deployer = DockerComposeDeployer(dep_type, dep_config, pkg_dir, out_dir, env, final_conf, self.global_conf, manifest, instance_name)
                deployer.deploy(self.cap_manager)
            else:
                print(f"Warning: Unknown deployer '{dep_type}'")
                
        # Register capabilities
        provides = manifest.get("capabilities", {}).get("provides", [])
        for p in provides:
            cap_name = p.get("name")
            if cap_name:
                self.cap_manager.register_provider(cap_name, instance_name, p.get("injectors", {}))

    def resolve_instance(self, name):
        if os.path.isdir(os.path.join(self.cont_dir, name)):
            return name
        
        matched = []
        for d in os.listdir(self.cont_dir):
            state_file = os.path.join(self.cont_dir, d, ".stegpkg-state.json")
            if os.path.isfile(state_file):
                try:
                    with open(state_file, "r") as f:
                        state = json.load(f)
                    if state.get("package") == name:
                        matched.append(d)
                except:
                    pass
                    
        if len(matched) == 1:
            return matched[0]
        elif len(matched) > 1:
            print(f"Error: Multiple instances of package '{name}' found: {matched}. Please specify exact instance ID.")
            sys.exit(1)
        else:
            print(f"Error: Instance or package '{name}' not found.")
            sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="stegOS Package Manager")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # INSTALL command
    install_p = subparsers.add_parser("install", help="Install a package")
    install_p.add_argument("packages", nargs="+", help="Package(s) to install")
    install_p.add_argument("--id", help="Instance ID for this installation (defaults to package name)")
    install_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")
    install_p.add_argument("--repo", help="Disambiguate if multiple repos provide package")
    install_p.add_argument("--config", help="Path to JSON file with config values")
    install_p.add_argument("--reconfigure", action="store_true", help="Force prompts")
    install_p.add_argument("--non-interactive", action="store_true", help="Abort instead of prompting")
    
    # RECONFIGURE command
    reconfigure_p = subparsers.add_parser("reconfigure", help="Regenerate configuration files for all packages in a group")
    reconfigure_p.add_argument("instance_ids", nargs="*", help="Instance ID(s) to reconfigure (defaults to all)")
    reconfigure_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")

    # REMOVE command
    remove_p = subparsers.add_parser("remove", help="Remove a package instance")
    remove_p.add_argument("instance_ids", nargs="+", help="Instance ID(s) to remove")
    remove_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")

    # UPGRADE command
    upgrade_p = subparsers.add_parser("upgrade", help="Upgrade packages and pull latest images")
    upgrade_p.add_argument("instance_ids", nargs="*", help="Instance ID(s) to upgrade (defaults to all)")
    upgrade_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")

    # UPDATE command
    update_p = subparsers.add_parser("update", help="Update app repositories via git pull")
    update_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")

    # LIST command
    list_p = subparsers.add_parser("list", help="List installed packages")
    list_p.add_argument("--group", help="Target Stegmap group (optional if only one exists)")

    args = parser.parse_args()
    
    engine = PackageEngine(args.group)
    
    if args.command == "install":
        if args.id and len(args.packages) > 1:
            print("Error: --id cannot be used when installing multiple packages.")
            sys.exit(1)
            
        unique_pkgs = []
        for p in args.packages:
            if p not in unique_pkgs:
                unique_pkgs.append(p)
            
        for pkg in unique_pkgs:
            pkg_dir = engine.find_package_dir(pkg, args.repo)
            cli_conf = {}
            if args.config:
                with open(args.config, "r") as f:
                    cli_conf = json.load(f)
            engine.process_package(pkg_dir, cli_conf, args.reconfigure, args.non_interactive, args.id)
            print(f"Successfully installed {pkg} as {args.id if args.id else pkg}!\n")
        
    elif args.command == "reconfigure":
        instances = [engine.resolve_instance(i) for i in args.instance_ids] if args.instance_ids else os.listdir(engine.cont_dir)
        reconfigured = 0
        for d in instances:
            state_file = os.path.join(engine.cont_dir, d, ".stegpkg-state.json")
            if os.path.isfile(state_file):
                with open(state_file, "r") as f:
                    state = json.load(f)
                pkg_name = state.get("package")
                if pkg_name:
                    try:
                        pkg_dir = engine.find_package_dir(pkg_name)
                        engine.process_package(pkg_dir, cli_conf={}, reconfigure=False, non_interactive=True, instance_id=d)
                        reconfigured += 1
                    except SystemExit:
                        print(f"Warning: Could not reconfigure package '{pkg_name}' for instance '{d}'")
                        continue
        print(f"Successfully reconfigured {reconfigured} instances in group {engine.group_name}.")
        
    elif args.command == "remove":
        for i_id in args.instance_ids:
            real_id = engine.resolve_instance(i_id)
            instance_dir = os.path.join(engine.cont_dir, real_id)
                
            print(f"Stopping instance '{real_id}'...")
            try:
                subprocess.run(["stegctl", "stop", real_id, "--group", engine.group_name], check=True)
            except subprocess.CalledProcessError:
                print("Warning: Failed to stop instance cleanly. Proceeding with removal...")
                
            import shutil
            shutil.rmtree(instance_dir)
            
            import glob
            conf_files = glob.glob(os.path.join(engine.conf_dir, f"*-{real_id}.json"))
            for cf in conf_files:
                os.remove(cf)
                
            print(f"Successfully removed instance '{real_id}'.")
        
    elif args.command == "upgrade":
        instances = [engine.resolve_instance(i) for i in args.instance_ids] if args.instance_ids else os.listdir(engine.cont_dir)
        
        upgraded = 0
        for d in instances:
            state_file = os.path.join(engine.cont_dir, d, ".stegpkg-state.json")
            if os.path.isfile(state_file):
                with open(state_file, "r") as f:
                    state = json.load(f)
                pkg_name = state.get("package")
                if pkg_name:
                    try:
                        pkg_dir = engine.find_package_dir(pkg_name)
                        engine.process_package(pkg_dir, cli_conf={}, reconfigure=False, non_interactive=True, instance_id=d)
                        print(f"[{d}] Pulling latest images...")
                        subprocess.run(["stegctl", "pull", d, "--group", engine.group_name], check=True)
                        print(f"[{d}] Restarting instance...")
                        subprocess.run(["stegctl", "start", d, "--group", engine.group_name], check=True)
                        upgraded += 1
                    except Exception as e:
                        print(f"Warning: Could not upgrade package '{pkg_name}' for instance '{d}': {e}")
                        continue
        print(f"Successfully upgraded {upgraded} instances in group {engine.group_name}.")
        
    elif args.command == "update":
        if not os.path.isdir(engine.repo_dir):
            print(f"Error: Repos directory {engine.repo_dir} does not exist.")
            sys.exit(1)
            
        updated = 0
        for d in os.listdir(engine.repo_dir):
            repo_path = os.path.join(engine.repo_dir, d)
            git_dir = os.path.join(repo_path, ".git")
            if os.path.isdir(git_dir):
                print(f"[{d}] Updating repository from remote...")
                try:
                    subprocess.run(["git", "config", "--global", "--add", "safe.directory", repo_path], check=True, capture_output=True)
                    subprocess.run(["git", "pull", "--rebase", "--autostash"], cwd=repo_path, check=True)
                    updated += 1
                except subprocess.CalledProcessError:
                    print(f"Warning: Failed to update repository '{d}'")
            else:
                print(f"[{d}] Skipping (Not a git repository)")
        print(f"Successfully updated {updated} repositories.")

    elif args.command == "list":
        if not os.path.isdir(engine.cont_dir):
            print(f"No packages installed in group '{engine.group_name}'.")
            return
            
        print(f"Installed packages in group '{engine.group_name}':")
        count = 0
        for d in sorted(os.listdir(engine.cont_dir)):
            state_file = os.path.join(engine.cont_dir, d, ".stegpkg-state.json")
            if os.path.isfile(state_file):
                with open(state_file, "r") as f:
                    state = json.load(f)
                pkg_name = state.get("package", "unknown")
                print(f"  - {d} (Package: {pkg_name})")
                count += 1
        
        if count == 0:
            print("  (none)")

if __name__ == "__main__":
    main()
