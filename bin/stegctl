#!/usr/bin/env python3
import os
import sys
import argparse
import json
import subprocess

STEGOS_ROOT = os.environ.get("STEGOS_ROOT", "/stegos")

class GroupManager:
    @staticmethod
    def resolve_group(group_prefix=None):
        containers_base = os.path.join(STEGOS_ROOT, "persistent")
        if not os.path.isdir(containers_base):
            if group_prefix:
                return group_prefix
            else:
                print("Error: No groups exist and no group specified.")
                sys.exit(1)
        
        all_groups = os.listdir(containers_base)
        
        if group_prefix is None:
            if len(all_groups) == 1:
                return all_groups[0]
            elif len(all_groups) > 1:
                print(f"Error: Multiple groups exist. You must specify --group. Available: {all_groups}")
                sys.exit(1)
            else:
                print("Error: No groups exist and no group specified.")
                sys.exit(1)
        
        matches = []
        for d in all_groups:
            if d == group_prefix or d.startswith(f"{group_prefix}_"):
                matches.append(d)
                
        if len(matches) == 1:
            return matches[0]
        elif len(matches) > 1:
            print(f"Error: Multiple groups match '{group_prefix}': {matches}")
            sys.exit(1)
        
        return group_prefix

class LifecycleManager:
    def __init__(self, group_prefix):
        self.group_name = GroupManager.resolve_group(group_prefix)
        self.cont_dir = os.path.join(STEGOS_ROOT, "persistent", self.group_name)

    def execute(self, action, package_name=None, extra_args=None):
        if extra_args is None:
            extra_args = []
            
        if not os.path.isdir(self.cont_dir):
            print(f"Error: Group directory '{self.cont_dir}' not found.")
            sys.exit(1)

        if package_name:
            target_path = os.path.join(self.cont_dir, package_name)
            if os.path.isdir(target_path):
                packages = [package_name]
            else:
                matched = []
                for d in os.listdir(self.cont_dir):
                    state_file = os.path.join(self.cont_dir, d, "backend", ".stegpkg-state.json")
                    if os.path.isfile(state_file):
                        try:
                            with open(state_file, "r") as f:
                                state = json.load(f)
                            if state.get("package") == package_name:
                                matched.append(d)
                        except:
                            pass
                
                if len(matched) == 1:
                    packages = matched
                elif len(matched) > 1:
                    print(f"Error: Multiple instances of '{package_name}' found. Please specify instance ID instead: {matched}")
                    sys.exit(1)
                else:
                    print(f"Error: No instance or package named '{package_name}' found in group '{self.group_name}'.")
                    sys.exit(1)
        else:
            packages = os.listdir(self.cont_dir)
        
        for pkg in packages:
            pkg_path = os.path.join(self.cont_dir, pkg, "backend")
            if not os.path.isdir(pkg_path):
                continue
                
            state_file = os.path.join(pkg_path, ".stegpkg-state.json")
            if not os.path.isfile(state_file):
                if package_name:
                    print(f"[{pkg}] No state file found. Was it installed with stegpkg?")
                continue
                
            with open(state_file, "r") as f:
                state = json.load(f)

            if action == "start":
                enabled_caps = state.get("enabled_caps", {})
                for cap, provs in enabled_caps.items():
                    if not isinstance(provs, list):
                        provs = [provs]
                    for p in provs:
                        print(f"[{pkg}] Ensuring provider '{p}' is started...")
                        # Avoid infinite loop by not passing the same package name
                        if p != pkg:
                            self.execute(action, p, extra_args)


            deployer = state.get("deployer")
            if deployer == "docker-compose":
                self._handle_docker_compose(action, pkg, pkg_path, extra_args)
            else:
                print(f"[{pkg}] Warning: Unknown deployer '{deployer}'")
                
    def _handle_docker_compose(self, action, pkg, pkg_path, extra_args):
        compose_file = os.path.join(pkg_path, "docker-compose.yml")
        if not os.path.isfile(compose_file):
            print(f"[{pkg}] Error: docker-compose.yml missing.")
            return
            
        print(f"[{pkg}] Executing docker-compose {action}...")
        
        cmd = ["docker", "compose", "-f", compose_file]
        if action == "start":
            cmd.extend(["up", "-d"])
        elif action == "stop":
            cmd.append("down")
        elif action == "status":
            cmd.append("ps")
        elif action == "logs":
            cmd.append("logs")
        elif action == "pull":
            cmd.append("pull")
        else:
            print(f"[{pkg}] Unknown action '{action}'")
            return
            
        if extra_args:
            cmd.extend(extra_args)
            
        try:
            subprocess.run(cmd, check=True)
        except subprocess.CalledProcessError as e:
            print(f"[{pkg}] Error: Command failed with code {e.returncode}")

def main():
    parser = argparse.ArgumentParser(description="stegOS Runtime Orchestrator")
    parser.add_argument("action", choices=["start", "stop", "restart", "status", "logs", "pull"], help="Action to perform")
    parser.add_argument("package", nargs="?", help="Specific package to perform action on (defaults to all)")
    parser.add_argument("--group", help="Target Stegmap group (optional if only one exists)")
    parser.add_argument("extra_args", nargs=argparse.REMAINDER, help="Additional arguments to pass to docker-compose")
    
    args = parser.parse_args()
    
    manager = LifecycleManager(args.group)
    
    if args.action == "restart":
        manager.execute("stop", args.package, args.extra_args)
        manager.execute("start", args.package, args.extra_args)
    else:
        manager.execute(args.action, args.package, args.extra_args)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nAborted by user.")
        sys.exit(130)
